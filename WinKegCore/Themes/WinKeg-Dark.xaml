<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinKegCore">
    
    <!-- Metadata -->
    <x:String x:Key="Theme.Name">WinKeg-Dark</x:String>
    <x:String x:Key="Theme.Author">Nathan Ziehnert</x:String>
    <x:String x:Key="Theme.DisplayName">WinKeg (Dark)</x:String>
    
    <!-- *** *** Colors *** *** -->
    <!-- Accent Colors -->
    <Color x:Key="WinKeg.Colors.Highlight">#FFA65D2D</Color>
    <Color x:Key="WinKeg.Colors.AccentBase">#FF754220</Color>
    <Color x:Key="WinKeg.Colors.Accent80">#CC754220</Color>
    <Color x:Key="WinKeg.Colors.Accent60">#99754220</Color>
    <Color x:Key="WinKeg.Colors.Accent40">#66754220</Color>
    <Color x:Key="WinKeg.Colors.Accent20">#33754220</Color>

    <!-- Base Colors -->
    <Color x:Key="WinKeg.Colors.ThemeForeground">#FFD5CCC0</Color>
    <Color x:Key="WinKeg.Colors.ThemeBackground">#FF000000</Color>
    
</ResourceDictionary>
